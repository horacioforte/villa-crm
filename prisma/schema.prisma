generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PapelUsuario {
  ADMIN
  GERENTE
  COMERCIAL
  OPERACIONAL
}

enum TipoPessoa {
  CONTATO
  DECISOR
  RESPONSAVEL_OBRA
  FINANCEIRO
}

enum InfluenciaDecisao {
  DECISOR
  INFLUENCIADOR
  TECNICO
  OPERACIONAL
  BLOQUEADOR
}

enum NivelRelacionamento {
  FRIO
  NEUTRO
  BOM
  EXCELENTE
}

enum StatusObra {
  PLANEJADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum TipoOperacao {
  LOCACAO
  EQUIPAMENTO_USADO
}

enum TipoServico {
  BOMBA_LANCA
  BOMBA_ESTACIONARIA
  TELEBELT
  BETONEIRA
  CENTRAL_IN_LOCO
  CONCRETO
  SERVICO_ESPECIAL
}

enum FaixaPotencial {
  ATE_100_MIL
  DE_100_A_500_MIL
  DE_500_MIL_A_2_MILHOES
  ACIMA_DE_2_MILHOES
}

enum CanalOrigem {
  INDICACAO
  CLIENTE_ATUAL
  GOOGLE
  LINKEDIN
  SITE
  VISITA_COMERCIAL
  OBRA_MAPEADA
  MARKETPLACE
  OLX
  EVENTO
  OUTROS
}

enum StatusOportunidade {
  NOVA
  EM_ATENDIMENTO
  PROPOSTA_ENVIADA
  NEGOCIACAO
  GANHA
  PERDIDA
}

enum TemperaturaOportunidade {
  FRIA
  MEDIA
  QUENTE
}

enum StatusPropostaComercial {
  RASCUNHO
  AGUARDANDO_APROVACAO
  ENVIADA
  APROVADA
  ACEITA
  REJEITADA
  VENCIDA
  CANCELADA
}

enum TipoBlocoProposta {
  BLOQUEADO
  EDITAVEL
  EDITAVEL_COM_APROVACAO
}

enum StatusExcecaoProposta {
  PENDENTE
  APROVADA
  REJEITADA
}

enum TipoProposta {
  BETONEIRA
  BOMBA
  CENTRAL
  TELEBELT
  OUTRO
}

enum TipoAtividade {
  LIGACAO
  WHATSAPP
  EMAIL
  VISITA
  REUNIAO
  REUNIAO_ONLINE
  PROPOSTA
  CONTRATO
  COBRANCA
  RETORNO_CLIENTE
  POS_VENDA
  LOGISTICA
  MANUTENCAO
  VISTORIA
  APRESENTACAO_COMERCIAL
  TAREFA_INTERNA
  OUTRO
}

enum PrioridadeTarefa {
  BAIXA
  MEDIA
  ALTA
  URGENTE
}

enum StatusTarefa {
  PENDENTE
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
  ATRASADA
}

enum TipoFeedback {
  BUG
  SUGESTAO
}

enum StatusFeedback {
  RECEBIDO
  EM_ANALISE
  IMPLEMENTADO
  DESCARTADO
}

enum TipoContato {
  TELEFONE
  WHATSAPP
  EMAIL
  REUNIAO
  VISITA
  OUTRO
}

enum TipoEquipamento {
  BOMBA_CONCRETO
  BETONEIRA
  OUTRO
}

enum StatusEquipamento {
  DISPONIVEL
  LOCADO
  MANUTENCAO
  VENDIDO
  INATIVO
}

model Usuario {
  id          String       @id @default(cuid())
  nome        String
  email       String       @unique
  senhaHash   String?
  telefone    String?
  cargo       String?
  papel       PapelUsuario @default(COMERCIAL)
  ativo       Boolean      @default(true)
  lastLoginAt DateTime?

  filialId String?
  filial   Filial? @relation(fields: [filialId], references: [id], onDelete: SetNull)

  oportunidades Oportunidade[]
  historicos    HistoricoContato[]

  empresasCriadas              Empresa[]                  @relation("EmpresaCreatedBy")
  empresasAtualizadas          Empresa[]                  @relation("EmpresaUpdatedBy")
  pessoasCriadas               Pessoa[]                   @relation("PessoaCreatedBy")
  pessoasAtualizadas           Pessoa[]                   @relation("PessoaUpdatedBy")
  obrasCriadas                 Obra[]                     @relation("ObraCreatedBy")
  obrasAtualizadas             Obra[]                     @relation("ObraUpdatedBy")
  oportunidadesCriadas         Oportunidade[]             @relation("OportunidadeCreatedBy")
  oportunidadesAtualizadas     Oportunidade[]             @relation("OportunidadeUpdatedBy")
  equipamentosCriados          Equipamento[]              @relation("EquipamentoCreatedBy")
  equipamentosAtualizados      Equipamento[]              @relation("EquipamentoUpdatedBy")
  historicosContatoCriados     HistoricoContato[]         @relation("HistoricoContatoCreatedBy")
  historicosContatoAtualizados HistoricoContato[]         @relation("HistoricoContatoUpdatedBy")
  propostasCriadas             PropostaComercial[]        @relation("PropostaComercialCreatedBy")
  propostasAtualizadas         PropostaComercial[]        @relation("PropostaComercialUpdatedBy")
  propostasCriadasGrupo        Proposta[]                 @relation("PropostaCreatedBy")
  templatesPropostaCriados     PropostaTemplateMaster[]   @relation("PropostaTemplateMasterCreatedBy")
  templatesPropostaAtualizados PropostaTemplateMaster[]   @relation("PropostaTemplateMasterUpdatedBy")
  excecoesPropostaSolicitadas  PropostaExcecaoAprovacao[] @relation("PropostaExcecaoSolicitante")
  excecoesPropostaDecididas    PropostaExcecaoAprovacao[] @relation("PropostaExcecaoAprovador")
  auditoriasProposta           PropostaAuditoriaCampo[]
  auditLogs                    AuditLog[]
  tarefasResponsavel           Tarefa[]                   @relation("TarefaResponsavel")
  tarefasCriadas               Tarefa[]                   @relation("TarefaCreatedBy")
  tarefasAtualizadas           Tarefa[]                   @relation("TarefaUpdatedBy")
  feedbacks                    Feedback[]
  conversasAtendidas           Conversa[]         @relation("ConversaAtendente")
  mensagensEnviadas            Mensagem[]         @relation("MensagemAutor")
  templatesRespostaCriados     TemplateResposta[] @relation("TemplateRespostaCriador")

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([filialId])
}

model Filial {
  id       String  @id @default(cuid())
  nome     String
  telefone String?
  email    String?
  endereco String?
  cidade   String
  estado   String
  cep      String?
  ativa    Boolean @default(true)

  usuarios     Usuario[]
  empresas     Empresa[]
  obras        Obra[]
  equipamentos Equipamento[]

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")
}

model Empresa {
  id           String  @id @default(cuid())
  razaoSocial  String
  nomeFantasia String?
  cnpj         String? @unique
  segmento     String?
  telefone     String?
  email        String?
  site         String?
  endereco     String?
  cidade       String?
  estado       String?
  cep          String?
  responsavel  String?
  observacoes  String?
  ativa        Boolean @default(true)

  filialId String?
  filial   Filial? @relation(fields: [filialId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Usuario? @relation("EmpresaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("EmpresaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  pessoas       Pessoa[]
  obras         Obra[]
  oportunidades Oportunidade[]
  historicos    HistoricoContato[]
  tarefas       Tarefa[]
  conversas     Conversa[]

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([filialId])
  @@index([createdById])
  @@index([updatedById])
  @@index([razaoSocial])
}

model Pessoa {
  id                  String              @id @default(cuid())
  nome                String
  email               String?
  telefone            String?
  whatsapp            String?
  cargo               String?
  tipoCargo           String?
  tipo                TipoPessoa          @default(CONTATO)
  influenciaDecisao   InfluenciaDecisao   @default(INFLUENCIADOR)
  nivelRelacionamento NivelRelacionamento @default(NEUTRO)
  aniversario         DateTime?
  observacoes         String?
  ativa               Boolean             @default(true)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   Usuario? @relation("PessoaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("PessoaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  obrasResponsavel Obra[]
  oportunidades    Oportunidade[]
  historicos       HistoricoContato[]
  tarefas          Tarefa[]
  conversas        Conversa[]

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([empresaId])
  @@index([createdById])
  @@index([updatedById])
  @@index([nome])
}

model Obra {
  id             String     @id @default(cuid())
  nome           String
  descricao      String?
  endereco       String?
  cidade         String?
  estado         String?
  cep            String?
  volumeEstimado Decimal?   @db.Decimal(12, 2)
  status         StatusObra @default(PLANEJADA)
  dataInicio     DateTime?
  dataTermino    DateTime?
  ativa          Boolean    @default(true)

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  filialId String?
  filial   Filial? @relation(fields: [filialId], references: [id], onDelete: SetNull)

  responsavelId String?
  responsavel   Pessoa? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Usuario? @relation("ObraCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("ObraUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  oportunidades Oportunidade[]
  tarefas       Tarefa[]

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([empresaId])
  @@index([filialId])
  @@index([responsavelId])
  @@index([createdById])
  @@index([updatedById])
}

model Oportunidade {
  id                 String                   @id @default(cuid())
  titulo             String
  descricao          String?
  tipo               TipoOperacao             @default(LOCACAO)
  tipoServico        TipoServico?
  status             StatusOportunidade       @default(NOVA)
  potencialOportunidade Decimal?              @db.Decimal(12, 2)
  faixaPotencial        FaixaPotencial?
  valorContrato         Decimal?              @db.Decimal(12, 2)
  probabilidade      Int?
  canalOrigem        CanalOrigem?
  motivoPerda        String?
  previsaoFechamento DateTime?
  fechadaEm          DateTime?
  ativa              Boolean                  @default(true)
  temperatura        TemperaturaOportunidade?
  temperaturaMotivo  String?

  empresaId String
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  pessoaId String?
  pessoa   Pessoa? @relation(fields: [pessoaId], references: [id], onDelete: SetNull)

  obraId String?
  obra   Obra?   @relation(fields: [obraId], references: [id], onDelete: SetNull)

  responsavelId String?
  responsavel   Usuario? @relation(fields: [responsavelId], references: [id], onDelete: SetNull)

  equipamentoId String?
  equipamento   Equipamento? @relation(fields: [equipamentoId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Usuario? @relation("OportunidadeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("OportunidadeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  historicos HistoricoContato[]
  propostas  PropostaComercial[]
  propostasGrupo Proposta[]
  tarefas    Tarefa[]
  conversas  Conversa[]

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([empresaId])
  @@index([pessoaId])
  @@index([obraId])
  @@index([responsavelId])
  @@index([equipamentoId])
  @@index([createdById])
  @@index([updatedById])
  @@index([ativa])
  @@index([status])
}

model Proposta {
  id           String       @id @default(cuid())
  numero       String       @unique
  tipoProposta TipoProposta
  descricao    String?

  oportunidadeId String
  oportunidade   Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  versoes PropostaComercial[]

  createdById String?
  createdBy   Usuario? @relation("PropostaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([oportunidadeId])
  @@index([createdById])
}

model PropostaComercial {
  id                    String                  @id @default(cuid())
  numeroProposta        String
  versao                Int                     @default(1)
  status                StatusPropostaComercial @default(RASCUNHO)
  templateUtilizado     String
  valorTotal            Decimal                 @db.Decimal(12, 2)
  validadeProposta      DateTime
  prazoExecucao         String?
  observacoesComerciais String?
  observacoesTecnicas   String?
  condicoesPagamento    String?
  horaExtra             Decimal?                @db.Decimal(12, 2)
  precoM3               Float?
  volumeMinimoM3        Float?
  pdfUrl                String?
  wordUrl               String?
  htmlSnapshot          String                  @db.Text
  ativa                 Boolean                 @default(false)

  propostaId String?
  proposta   Proposta? @relation(fields: [propostaId], references: [id], onDelete: SetNull)

  templateMasterId String?
  templateMaster   PropostaTemplateMaster? @relation(fields: [templateMasterId], references: [id], onDelete: SetNull)

  oportunidadeId String
  oportunidade   Oportunidade @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  createdById String?
  criadoPor   Usuario? @relation("PropostaComercialCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("PropostaComercialUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blocos     PropostaBloco[]
  excecoes   PropostaExcecaoAprovacao[]
  auditorias PropostaAuditoriaCampo[]
  tarefas    Tarefa[]
  itens      PropostaItem[]

  @@unique([numeroProposta, versao])
  @@index([propostaId])
  @@index([oportunidadeId])
  @@index([templateMasterId])
  @@index([createdById])
  @@index([updatedById])
  @@index([status])
  @@index([validadeProposta])
}

model PropostaItem {
  id              String  @id @default(cuid())
  ordem           Int     @default(0)
  descricao       String
  quantidade      Int     @default(1)
  precoM3         Float?
  volumeMinimoM3  Float?
  horasGarantidas String?
  precoUnitario   Float?
  horaExtra       Float?
  valorTotal      Float

  propostaId String
  proposta   PropostaComercial @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  equipamentoId String?
  equipamento   Equipamento? @relation(fields: [equipamentoId], references: [id], onDelete: SetNull)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([propostaId])
  @@index([equipamentoId])
}

model PropostaTemplateMaster {
  id          String  @id @default(cuid())
  codigo      String  @unique
  nome        String
  tipoServico String
  descricao   String? @db.Text
  versao      Int     @default(1)
  ativo       Boolean @default(true)

  createdById String?
  createdBy   Usuario? @relation("PropostaTemplateMasterCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("PropostaTemplateMasterUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  blocos    PropostaTemplateBloco[]
  propostas PropostaComercial[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([codigo])
  @@index([ativo])
  @@index([createdById])
  @@index([updatedById])
}

model PropostaTemplateBloco {
  id       String            @id @default(cuid())
  chave    String
  titulo   String
  tipo     TipoBlocoProposta
  ordem    Int
  conteudo String            @db.Text

  templateMasterId String
  templateMaster   PropostaTemplateMaster @relation(fields: [templateMasterId], references: [id], onDelete: Cascade)

  blocosProposta PropostaBloco[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([templateMasterId, chave])
  @@index([templateMasterId, ordem])
  @@index([tipo])
}

model PropostaBloco {
  id               String            @id @default(cuid())
  chave            String
  titulo           String
  tipo             TipoBlocoProposta
  ordem            Int
  conteudoOriginal String            @db.Text
  conteudoAtual    String            @db.Text
  editado          Boolean           @default(false)

  propostaId String
  proposta   PropostaComercial @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  templateBlocoId String?
  templateBloco   PropostaTemplateBloco? @relation(fields: [templateBlocoId], references: [id], onDelete: SetNull)

  excecoes   PropostaExcecaoAprovacao[]
  auditorias PropostaAuditoriaCampo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propostaId, chave])
  @@index([propostaId, ordem])
  @@index([templateBlocoId])
  @@index([tipo])
}

model PropostaExcecaoAprovacao {
  id            String                @id @default(cuid())
  campo         String
  valorAnterior Json?
  valorProposto Json?
  justificativa String                @db.Text
  status        StatusExcecaoProposta @default(PENDENTE)
  decisaoMotivo String?               @db.Text
  decididoEm    DateTime?

  propostaId String
  proposta   PropostaComercial @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  blocoId String?
  bloco   PropostaBloco? @relation(fields: [blocoId], references: [id], onDelete: SetNull)

  solicitanteId String?
  solicitante   Usuario? @relation("PropostaExcecaoSolicitante", fields: [solicitanteId], references: [id], onDelete: SetNull)

  aprovadorId String?
  aprovador   Usuario? @relation("PropostaExcecaoAprovador", fields: [aprovadorId], references: [id], onDelete: SetNull)

  auditorias PropostaAuditoriaCampo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propostaId, status])
  @@index([blocoId])
  @@index([solicitanteId])
  @@index([aprovadorId])
  @@index([createdAt])
}

model PropostaAuditoriaCampo {
  id             String                   @id @default(cuid())
  campo          String
  valorAnterior  Json?
  valorNovo      Json?
  justificativa  String?                  @db.Text
  statusAnterior StatusPropostaComercial?
  statusNovo     StatusPropostaComercial?
  versao         Int

  propostaId String
  proposta   PropostaComercial @relation(fields: [propostaId], references: [id], onDelete: Cascade)

  blocoId String?
  bloco   PropostaBloco? @relation(fields: [blocoId], references: [id], onDelete: SetNull)

  excecaoId String?
  excecao   PropostaExcecaoAprovacao? @relation(fields: [excecaoId], references: [id], onDelete: SetNull)

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([propostaId, createdAt])
  @@index([blocoId])
  @@index([excecaoId])
  @@index([usuarioId])
  @@index([campo])
}

model Tarefa {
  id             String           @id @default(cuid())
  titulo         String
  descricao      String?
  tipo           TipoAtividade    @default(LIGACAO)
  prioridade     PrioridadeTarefa @default(MEDIA)
  status         StatusTarefa     @default(PENDENTE)
  dataVencimento DateTime
  horaVencimento String?
  observacoes    String?
  resultado      String?
  resultadoCodigo String?
  concluidaEm    DateTime?

  oportunidadeId String?
  oportunidade   Oportunidade? @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  pessoaId String?
  pessoa   Pessoa? @relation(fields: [pessoaId], references: [id], onDelete: SetNull)

  obraId String?
  obra   Obra?   @relation(fields: [obraId], references: [id], onDelete: SetNull)

  propostaId String?
  proposta   PropostaComercial? @relation(fields: [propostaId], references: [id], onDelete: SetNull)

  responsavelId String?
  responsavel   Usuario? @relation("TarefaResponsavel", fields: [responsavelId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Usuario? @relation("TarefaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("TarefaUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  // Hooks futuros: sincronizar tarefa com WhatsApp e Google Calendar.
  whatsappMessageId     String?
  googleCalendarEventId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([oportunidadeId])
  @@index([empresaId])
  @@index([pessoaId])
  @@index([obraId])
  @@index([propostaId])
  @@index([responsavelId])
  @@index([status])
  @@index([dataVencimento])
  @@index([prioridade])
}

model HistoricoContato {
  id             String      @id @default(cuid())
  tipo           TipoContato
  resumo         String
  detalhes       String?
  dataContato    DateTime    @default(now())
  proximoContato DateTime?

  oportunidadeId String?
  oportunidade   Oportunidade? @relation(fields: [oportunidadeId], references: [id], onDelete: Cascade)

  empresaId String?
  empresa   Empresa? @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  pessoaId String?
  pessoa   Pessoa? @relation(fields: [pessoaId], references: [id], onDelete: SetNull)

  usuarioId String?
  usuario   Usuario? @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Usuario? @relation("HistoricoContatoCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("HistoricoContatoUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([oportunidadeId])
  @@index([empresaId])
  @@index([pessoaId])
  @@index([usuarioId])
  @@index([createdById])
  @@index([updatedById])
  @@index([dataContato])
}

model Equipamento {
  id           String            @id @default(cuid())
  codigo       String            @unique
  nome         String
  tipo         TipoEquipamento
  marca        String?
  modelo       String?
  ano          Int?
  numeroSerie  String?
  status       StatusEquipamento @default(DISPONIVEL)
  valorLocacao Decimal?          @db.Decimal(12, 2)
  valorM3      Float?
  volumeMinimoM3 Float?
  valorVenda   Decimal?          @db.Decimal(12, 2)
  observacoes  String?

  filialId String?
  filial   Filial? @relation(fields: [filialId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   Usuario? @relation("EquipamentoCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  updatedById String?
  updatedBy   Usuario? @relation("EquipamentoUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  oportunidades Oportunidade[]
  propostaItens PropostaItem[]

  createdAt DateTime @default(now()) @map("criadoEm")
  updatedAt DateTime @updatedAt @map("atualizadoEm")

  @@index([filialId])
  @@index([createdById])
  @@index([updatedById])
  @@index([status])
}

model Feedback {
  id            String         @id @default(cuid())
  numero        Int            @unique
  tipo          TipoFeedback
  titulo        String
  descricao     String
  area          String?
  status        StatusFeedback @default(RECEBIDO)
  respostaAdmin String?

  autorId String
  autor   Usuario @relation(fields: [autorId], references: [id])

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([autorId])
  @@index([status])
  @@index([tipo])
  @@index([numero])
}

model AgenteConfig {
  id              String   @id @default(cuid())
  agente          String   @unique
  nome            String
  descricao       String
  personalidade   String   @db.Text
  regrasQuente    String   @db.Text
  regrasMedia     String   @db.Text
  regrasFria      String   @db.Text
  ignorar         String   @db.Text
  exemplosLead    String   @db.Text
  exemplosNaoLead String   @db.Text
  historicoErros  String   @db.Text
  promptCompleto  String   @db.Text
  ativo           Boolean  @default(true)
  atualizadoEm    DateTime @updatedAt
  atualizadoPor   String?
}

// ─────────────────────────────────────────────
// CENTRAL DE ATENDIMENTO — nunca remover, só acrescentar
// ─────────────────────────────────────────────

enum CanalAtendimento {
  WHATSAPP
  EMAIL
  TELEFONE
  CHAT
}

enum StatusConversa {
  ABERTA
  PENDENTE
  CONCLUIDA
  SPAM
}

enum DirecaoMensagem {
  ENTRADA
  SAIDA
}

enum AutorMensagem {
  IA
  HUMANO
  SISTEMA
}

enum StatusMensagem {
  ENVIADA
  ENTREGUE
  LIDA
  ERRO
}

model Conversa {
  id             String           @id @default(cuid())
  canal          CanalAtendimento @default(WHATSAPP)
  status         StatusConversa   @default(ABERTA)
  instanceName   String           // maria-villa, joao-villa, morgana-villa, taciane-villa
  chatwootId     Int?
  telefone       String?          // número do contato no WhatsApp
  nomeContato    String?

  // Vínculo opcional com CRM
  empresaId      String?
  empresa        Empresa? @relation(fields: [empresaId], references: [id], onDelete: SetNull)

  pessoaId       String?
  pessoa         Pessoa? @relation(fields: [pessoaId], references: [id], onDelete: SetNull)

  oportunidadeId String?
  oportunidade   Oportunidade? @relation(fields: [oportunidadeId], references: [id], onDelete: SetNull)

  // Atendente responsável (humano)
  atendidoPorId  String?
  atendidoPor    Usuario? @relation("ConversaAtendente", fields: [atendidoPorId], references: [id], onDelete: SetNull)

  ultimaMensagemEm DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  mensagens Mensagem[]

  @@index([status])
  @@index([instanceName])
  @@index([empresaId])
  @@index([pessoaId])
  @@index([oportunidadeId])
  @@index([atendidoPorId])
  @@index([ultimaMensagemEm])
}

model Mensagem {
  id           String          @id @default(cuid())
  conteudo     String          @db.Text
  direcao      DirecaoMensagem
  autor        AutorMensagem   @default(IA)
  status       StatusMensagem  @default(ENVIADA)
  waMessageId  String?         // ID retornado pela Evolution API
  mimeType     String?         // para arquivos/áudio
  mediaUrl     String?

  conversaId   String
  conversa     Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  // Quem enviou (se humano)
  autorUsuarioId String?
  autorUsuario   Usuario? @relation("MensagemAutor", fields: [autorUsuarioId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([conversaId])
  @@index([conversaId, createdAt])
  @@index([autorUsuarioId])
  @@index([waMessageId])
}

model TemplateResposta {
  id          String   @id @default(cuid())
  nome        String
  conteudo    String   @db.Text
  categoria   String?
  ativo       Boolean  @default(true)

  criadoPorId String?
  criadoPor   Usuario? @relation("TemplateRespostaCriador", fields: [criadoPorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([criadoPorId])
  @@index([ativo])
}

model AuditLog {
  id        String  @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  metadata  Json?
  ip        String?
  userAgent String?

  userId String?
  user   Usuario? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}
